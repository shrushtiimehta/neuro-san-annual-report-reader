            "name": "CognizantDocExtractor",
            "function": {
                "description": """Retrieves pre-extracted text from Cognizant's 2024 Annual Report and 10-K SEC filing.
                Accepts either a section-level key (returns all files in that section) or a file-level key
                (returns a single specific document). Use this to look up financial figures, strategic priorities,
                AI platform details, acquisition information, case studies, risk disclosures, governance details,
                and all other factual content from the report. You MUST call this tool to read document content.""",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "app_name": {
                            "type": "string",
                            "description": "The document key to retrieve, as specified in each agent's instructions.",
                        }
                    },
                    "required": ["app_name"]
                }
            },
